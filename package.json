{
  "name": "soulfulhorizon-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "npm run build",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "npm run build && npx wrangler pages dev out",
    "deploy": "npm run build && npx wrangler pages deploy out",
    "upgrade": "npx npm-check-updates -u && npm install"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=9.6.0"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@next/mdx": "^15.3.3",
    "acorn": "^8.16.0",
    "acorn-jsx": "^5.3.2",
    "clsx": "^2.1.1",
    "escape-string-regexp": "^5.0.0",
    "fast-glob": "^3.3.3",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.7",
    "rehype-slug": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.2.9",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "^15.3.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "recma-import-images": "0.0.3",
    "rehype-unwrap-images": "^1.0.0",
    "remark-gfm": "^4.0.1",
    "remark-rehype-wrap": "0.0.5",
    "tailwindcss": "^4",
    "typescript": "^6",
    "unified-conditional": "0.0.2",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.0"
